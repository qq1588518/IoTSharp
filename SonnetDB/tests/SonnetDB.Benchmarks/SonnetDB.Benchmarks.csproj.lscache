/debug+
/debug:portable
/filealign:512
/optimize-
/out:obj\Debug\net10.0\SonnetDB.Benchmarks.dll
/refout:obj\Debug\net10.0\refint\SonnetDB.Benchmarks.dll
/target:exe
/warnaserror+
/utf8output
/deterministic+
/langversion:latest
/warnaserror+:NU1605,SYSLIB0011

