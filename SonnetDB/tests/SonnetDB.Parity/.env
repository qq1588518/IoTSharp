# Parity 测试栈环境变量（docker-compose.parity.yml + 适配器默认值共享）。
# 端口采用 2x000 偏移方案，避免与本机已有服务默认端口冲突。
COMPOSE_PROJECT_NAME=sonnetdb-parity

# ── 主机暴露端口（port-offset 25xxx / 2xxxx） ──────────────────────────────
PARITY_SONNETDB_PORT=25080
PARITY_PG_PORT=25432
PARITY_REDIS_PORT=26379
PARITY_INFLUX_PORT=28086
PARITY_VM_PORT=28428
PARITY_MINIO_API_PORT=25000
PARITY_MINIO_CONSOLE_PORT=25090
PARITY_NATS_PORT=24222
PARITY_MOSQUITTO_PORT=21883
PARITY_MEILI_PORT=27700
PARITY_QDRANT_PORT=26333
PARITY_CLICKHOUSE_HTTP_PORT=28123

# ── PostgreSQL 凭证（PostgresAdapter 默认值与此一致） ──────────────────────
PARITY_PG_HOST=127.0.0.1
PARITY_PG_USER=parity
PARITY_PG_PASSWORD=parity
PARITY_PG_DB=parity

# ── 其他竞品凭证（本地一次性，非密钥） ────────────────────────────────────
PARITY_MINIO_ROOT_USER=parity
PARITY_MINIO_ROOT_PASSWORD=parity12345
PARITY_MEILI_MASTER_KEY=parity-master-key
PARITY_MEILI_URL=http://127.0.0.1:27700
PARITY_INFLUX_URL=http://127.0.0.1:28086
PARITY_INFLUX_USER=admin
PARITY_INFLUX_PASSWORD=password123
PARITY_INFLUX_ORG=sndb
PARITY_INFLUX_BUCKET=parity
PARITY_INFLUX_TOKEN=parity-token
PARITY_VM_URL=http://127.0.0.1:28428

# ── 数据集规模 ────────────────────────────────────────────────────────────
PARITY_DATASET_ROWS=10000
PARITY_TSDB_INGEST_POINTS=10000
PARITY_FULLTEXT_DOCUMENTS=5000
PARITY_FULLTEXT_BM25_DOCUMENTS=2000
PARITY_TPCC_WAREHOUSES=5
PARITY_TPCC_SECONDS=1800
# 默认不跑 30 分钟长场景；设为 1 后 tpcc_lite 使用 PARITY_TPCC_SECONDS。
PARITY_TPCC_FULL=0
